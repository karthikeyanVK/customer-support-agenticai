# Microsoft AI Foundry (Azure OpenAI)
# Find these in: Azure Portal → AI Foundry → your project → Deployments

# Your Azure OpenAI resource name (e.g. "my-openai-resource")
AZURE_OPENAI_API_INSTANCE_NAME=your-resource-name

# Your deployment name (e.g. "gpt-4o-mini")
AZURE_OPENAI_API_DEPLOYMENT_NAME=your-deployment-name

# API key from Azure Portal
AZURE_OPENAI_API_KEY=your-azure-openai-key

# API version — use the default below unless your deployment requires a different one
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# SQLite database
DATABASE_URL="file:./prisma/dev.db"
